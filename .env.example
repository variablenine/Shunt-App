# Copy to `.env` (or put the same keys in `local.properties`) and fill in.
# Real keys are gitignored — never commit them.

# HERE Routing / Geocoding / Autosuggest API key (one key covers all three).
# Get one at https://platform.here.com/ (Access Manager -> your app -> API Keys).
HERE_API_KEY=

# Tessie (Part B) — the production vehicle client. Without both of these the
# app runs against the fake vehicle client. The token is your own Tessie
# bearer token; the VIN is your own vehicle. Never commit real values.
TESSIE_TOKEN=
TESSIE_VIN=
